{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://owbanpick.local/schema/match-config.schema.json",
  "title": "OW Ban Pick 比赛配置模板",
  "description": "全局管理员导入、导出配置模板以及房间管理员高级导入使用的格式。",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "id", "name", "config"],
  "properties": {
    "$schema": { "type": "string", "description": "可选的 JSON Schema 地址，不参与比赛逻辑。" },
    "schemaVersion": { "const": 1, "description": "配置文件格式版本。" },
    "id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9_-]{0,63}$", "description": "模板稳定标识，只允许小写字母、数字、下划线和短横线。" },
    "name": { "type": "string", "minLength": 1, "maxLength": 80, "description": "用户界面显示的模板名称，例如杯赛 A。" },
    "description": { "type": "string", "maxLength": 500, "description": "模板用途和主要规则摘要。" },
    "config": { "$ref": "#/$defs/config" }
  },
  "$defs": {
    "checkpoint": {
      "type": "object",
      "additionalProperties": false,
      "required": ["enabled", "label"],
      "properties": {
        "enabled": { "type": "boolean", "description": "是否在回退检查点列表中启用。" },
        "label": { "type": "string", "minLength": 1, "maxLength": 40, "description": "检查点显示名称。" }
      }
    },
    "checkpointStage": {
      "type": "object",
      "additionalProperties": false,
      "required": ["preCountdown", "mapPick", "lineupPick", "firstSecondBanChoice", "firstBan", "secondBan", "scorePick"],
      "properties": {
        "preCountdown": { "$ref": "#/$defs/checkpoint", "description": "本张地图开始前倒计时检查点。" },
        "mapPick": { "$ref": "#/$defs/checkpoint", "description": "选择地图检查点。" },
        "lineupPick": { "$ref": "#/$defs/checkpoint", "description": "选择上场成员检查点。" },
        "firstSecondBanChoice": { "$ref": "#/$defs/checkpoint", "description": "选择先后 Ban 检查点。" },
        "firstBan": { "$ref": "#/$defs/checkpoint", "description": "先手 Ban 检查点。" },
        "secondBan": { "$ref": "#/$defs/checkpoint", "description": "后手 Ban 检查点。" },
        "scorePick": { "$ref": "#/$defs/checkpoint", "description": "比分录入检查点。" }
      }
    },
    "seconds": { "type": "integer", "minimum": 1, "maximum": 3600 },
    "config": {
      "type": "object",
      "additionalProperties": false,
      "required": ["matchName", "teams", "matchFormat", "stageCount", "checkpoints", "stageLimits", "mapPool", "mapSelectionMode", "firstMapMode", "fixedMapOrderText", "rosterMode", "presetRosterText", "firstBanPolicy", "openingSidePolicy", "scoreReportMode"],
      "properties": {
        "matchName": { "type": "string", "minLength": 1, "maxLength": 120, "description": "房间主页面显示的比赛名称。" },
        "teams": {
          "type": "object",
          "additionalProperties": false,
          "required": ["left", "right"],
          "properties": {
            "left": { "type": "string", "minLength": 1, "maxLength": 60, "description": "蓝色方队伍名称。" },
            "right": { "type": "string", "minLength": 1, "maxLength": 60, "description": "红色方队伍名称。" }
          }
        },
        "matchFormat": { "enum": ["ft2", "ft3", "ft4"], "description": "先赢 2、3 或 4 张地图的比赛赛制。" },
        "stageCount": { "enum": [3, 5, 7], "description": "地图槽位数量；必须分别与 FT2、FT3、FT4 对应。" },
        "checkpoints": { "type": "array", "minItems": 3, "maxItems": 7, "items": { "$ref": "#/$defs/checkpointStage" }, "description": "每张地图可回退的检查点。数组长度必须等于 stageCount。" },
        "stageLimits": {
          "type": "object",
          "additionalProperties": false,
          "required": ["preStartRestSeconds", "mapSelectSeconds", "playerSelectSeconds", "firstBanChoiceSeconds", "firstBanActionSeconds", "secondBanActionSeconds", "scoreConfirmSeconds", "postMatchRestSeconds"],
          "properties": {
            "preStartRestSeconds": { "$ref": "#/$defs/seconds", "description": "开赛前或下一图开始前休息秒数。" },
            "mapSelectSeconds": { "$ref": "#/$defs/seconds", "description": "选择地图秒数。" },
            "playerSelectSeconds": { "$ref": "#/$defs/seconds", "description": "选择上场成员秒数。" },
            "firstBanChoiceSeconds": { "$ref": "#/$defs/seconds", "description": "选择先后 Ban 秒数。" },
            "firstBanActionSeconds": { "$ref": "#/$defs/seconds", "description": "先手 Ban 秒数。" },
            "secondBanActionSeconds": { "$ref": "#/$defs/seconds", "description": "后手 Ban 秒数。" },
            "scoreConfirmSeconds": { "$ref": "#/$defs/seconds", "description": "比分确认秒数。" },
            "postMatchRestSeconds": { "$ref": "#/$defs/seconds", "description": "每张地图结束后的休息秒数。" }
          }
        },
        "mapPool": { "type": "object", "minProperties": 1, "additionalProperties": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "type": "string", "minLength": 1 } }, "description": "以地图类别为键、英文地图名数组为值的地图池。" },
        "mapSelectionMode": { "enum": ["unique_map", "unique_mode_until_cycle", "first_mode_then_unique_mode", "strict_mode_order", "fixed_map_order"], "description": "地图不重复、类别轮换、首图限定类别、严格类别顺序或固定地图顺序。" },
        "firstMapMode": { "type": "string", "minLength": 1, "description": "首图限定类别模式使用的地图类别。" },
        "fixedMapOrderText": { "type": "string", "maxLength": 20000, "description": "固定地图顺序，每行一个英文地图名。" },
        "rosterMode": { "enum": ["free_input", "preset_only", "skip"], "description": "双方自由输入、只使用预设成员或跳过阵容选择。" },
        "presetRosterText": { "type": "string", "maxLength": 20000, "description": "预设成员；格式为蓝色方和红色方各一行，成员用逗号分隔。" },
        "firstBanPolicy": { "enum": ["allow_loser_choose", "loser_must_first", "no_ban"], "description": "败者选择先后 Ban、败者必须先 Ban 或不启用英雄 Ban。" },
        "openingSidePolicy": { "enum": ["random", "red", "blue"], "description": "第一张地图的首次先手方。" },
        "scoreReportMode": { "enum": ["admin_only", "team_submit_opponent_confirm"], "description": "管理员录入比分，或一方提交后由另一方确认。" }
      }
    }
  }
}
